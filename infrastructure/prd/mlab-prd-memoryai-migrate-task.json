{
  "family": "mlab-prd-memoryai-migrate-task",
  "containerDefinitions": [
    {
      "name": "memoryai-migrate",
      "image": "477952376032.dkr.ecr.ap-northeast-1.amazonaws.com/mlab-prd-memoryai-backend:PLACEHOLDER",
      "cpu": 0,
      "essential": true,
      "command": ["node", "dist/db/migrate.js"],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "APP_ENV", "value": "prd" },
        { "name": "PORT", "value": "8080" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "CORS_ORIGIN", "value": "https://v5.memoryai.jp" },
        { "name": "CORS_ORIGIN_PATTERN", "value": "" },
        { "name": "AWS_REGION", "value": "ap-northeast-1" },
        { "name": "SQS_QUEUE_URL", "value": "https://sqs.ap-northeast-1.amazonaws.com/477952376032/mlab-prd-memoryai-backend.fifo" },
        { "name": "DB_HOST", "value": "mlab-prd-memoryai-db.cluster-cccjvne0mxoc.ap-northeast-1.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "memoryai" },
        { "name": "DB_USER", "value": "memoryai_app" },
        { "name": "DB_REGION", "value": "ap-northeast-1" },
        { "name": "FREE_MONTHLY_REPORT_LIMIT", "value": "5" },
        { "name": "UNLIMITED_USER_IDS", "value": "" }
      ],
      "secrets": [
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-northeast-1:477952376032:parameter/prd/memoryai/anthropic-api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mlab-prd-memoryai-migrate",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "migrate"
        }
      },
      "readonlyRootFilesystem": true,
      "linuxParameters": {
        "initProcessEnabled": true
      }
    }
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::477952376032:role/mlab-prd-memoryai-backend-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::477952376032:role/mlab-prd-memoryai-backend-ecs-task-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  }
}
