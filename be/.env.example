# All variables below are validated at startup by src/config/env.ts.
# Anything marked "required" must be set (and non-empty) — there are no
# code-level defaults. Anything marked "required (raw)" must be defined but
# may be empty.

# Server (all required)
NODE_ENV=development
APP_ENV=dev
PORT=3001
LOG_LEVEL=debug

# Comma-separated list of exact allowed origins. (required)
CORS_ORIGIN=http://localhost:8080

# Comma-separated list of regex patterns for dynamic origins (e.g. Amplify previews).
# Optional — leave blank when no pattern matching is needed.
# STG preview: ^https://[^.]+\.djqagj8shabc6\.amplifyapp\.com$
CORS_ORIGIN_PATTERN=

# PostgreSQL — set EITHER DATABASE_URL or the DB_HOST group below.
# When DB_HOST is set, IAM auth is used (RDS Signer) and DATABASE_URL is ignored.

# Local dev only (devcontainer / local Postgres)
DATABASE_URL=postgresql://memory_ai:memory_ai@postgres:5432/memory_ai

# Production/staging (RDS IAM auth). All four must be set together when DB_HOST is set.
# Leave blank for local dev.
# DB_HOST=
# DB_PORT=5432
# DB_NAME=memoryai
# DB_USER=memoryai_app
# DB_REGION=ap-northeast-1

# AWS region for SQS / RDS Signer (required)
AWS_REGION=ap-northeast-1

# SQS (required)
SQS_QUEUE_URL=

# Anthropic API Key (required, must start with sk-ant-)
ANTHROPIC_API_KEY=

# Report limits
# Monthly report cap for free users (required, integer)
FREE_MONTHLY_REPORT_LIMIT=5
# Comma-separated UUIDs that bypass the monthly limit. Required (raw) — must
# be defined, but empty string is valid (= no users bypass).
UNLIMITED_USER_IDS=
