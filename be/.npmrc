# Refuse to install if the running Node.js version doesn't satisfy
# `engines.node` in package.json. Without this, `engines` is advisory and
# silently ignored — which masks "developer is on the wrong Node" bugs
# until they fail in CI or production.
engine-strict=true

# Always require a present and up-to-date package-lock.json. `npm ci`
# already enforces this in CI/Docker, but setting it here means even ad-hoc
# `npm install` runs maintain lockfile integrity.
package-lock=true

# Reject lockfiles that are out of sync with the registry (npm 10+).
# Catches lockfile tampering and accidental drift.
fund=false
audit=true
