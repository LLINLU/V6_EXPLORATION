{
	"name": "memory-ai-be",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0 <25.0.0"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"db:migrate": "tsx src/db/migrate.ts",
		"db:generate": "drizzle-kit generate",
		"db:check": "drizzle-kit check",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:model": "vitest run anthropicModelAlias"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@aws-sdk/client-sqs": "^3.1038.0",
		"@aws-sdk/rds-signer": "^3.1036.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"drizzle-orm": "^0.45.2",
		"express": "^5.1.0",
		"pg": "^8.13.3",
		"pino": "^9.5.0",
		"swagger-ui-express": "^5.0.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.2",
		"@types/node": "^22.5.5",
		"@types/pg": "^8.11.11",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.6",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "^11.2.2",
		"supertest": "^7.0.0",
		"tsx": "^4.19.4",
		"typescript": "^5.5.3",
		"vitest": "^4.1.6"
	}
}
