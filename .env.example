# Root .env — used by docker-compose.yml and Next.js.
# Copy to .env and fill in the values.

# ── Supabase (required for FE auth + data) ──────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Backend API (FE → BE) ───────────────────────────────────────
# For local dev via docker-compose, this should be http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── Backend secrets (also readable from be/.env) ────────────────
# Required by the BE container. Set here OR in be/.env (not both).
ANTHROPIC_API_KEY=
SQS_QUEUE_URL=

# ── AWS (optional, for SQS access from local dev) ───────────────
# AWS_PROFILE=AdministratorAccess-<account-id>

NEXT_PUBLIC_API_BASE_URL=https://backend.stg.memoryai.jp

# ─── Local-dev affordances (do NOT set in production) ───
# When the FE hits the BE directly (no API Gateway in front), the FE has to
# inject headers that API Gateway would normally set. Both default to off; set
# them only for local development.
#
# Set to "true" only when calling the backend directly (bypassing API Gateway,
# e.g. local dev against `be/`). When unset/false, the FE will not send the
# X-User-Id header — API Gateway injects it from the Lambda Authorizer.
# NEXT_PUBLIC_SEND_USER_ID_HEADER=true

# X-Source-IP injection: BE's ipRestriction middleware reads this header to
# evaluate the per-user IP allowlist. In production API Gateway injects it
# from $context.identity.sourceIp. For local testing, simulate a specific
# source IP here to exercise allow / deny scenarios against the allowlist.
#NEXT_PUBLIC_DEV_SOURCE_IP=<your-ip-address>
